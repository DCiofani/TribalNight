# ── Totem Night — variabili ambiente (copiare in .env.local) ──────────────────
# Progetto a EVENTO SINGOLO per deploy: il client non passa mai event_id a mano,
# lo risolve via la RPC current_event() (vedi lib/events.ts).

# Supabase — client (pubbliche, sicure lato browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — SOLO server/CI (applicare migrazione, set claim staff). MAI nel client.
SUPABASE_SERVICE_ROLE_KEY=

# Connessione diretta al DB (per psql / migrazioni in CI)
SUPABASE_DB_URL=

# Branding placeholder (vincolo 5): nome app sostituibile senza toccare codice.
# I colori vivono in app/globals.css (:root).
NEXT_PUBLIC_APP_NAME=Totem Night
